{
  "buildCommand": "npm install --legacy-peer-deps && npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/", "destination": "/es", "permanent": true },

    { "source": "/sobre-nosotros", "destination": "/es/sobre-nosotros", "permanent": true },
    { "source": "/como-trabajamos", "destination": "/es/como-trabajamos", "permanent": true },
    { "source": "/servicios", "destination": "/es/servicios", "permanent": true },
    { "source": "/servicios/auditorias", "destination": "/es/servicios/auditorias", "permanent": true },
    { "source": "/servicios/landing-pages", "destination": "/es/servicios/landing-pages", "permanent": true },
    { "source": "/servicios/ecommerce", "destination": "/es/servicios/ecommerce", "permanent": true },
    { "source": "/servicios/sistemas-gestion", "destination": "/es/servicios/sistemas-gestion", "permanent": true },
    { "source": "/servicios/paquetes", "destination": "/es/servicios/paquetes", "permanent": true },
    { "source": "/casos-reales", "destination": "/es/casos-reales", "permanent": true },
    { "source": "/landing-pages", "destination": "/es/landing-pages", "permanent": true },
    { "source": "/arquitectura", "destination": "/es/arquitectura", "permanent": true },
    { "source": "/gastronomia", "destination": "/es/gastronomia", "permanent": true },
    { "source": "/es/paquetes", "destination": "/es/servicios/paquetes", "permanent": true },
    { "source": "/en/paquetes", "destination": "/en/servicios/paquetes", "permanent": true }
  ],
  "rewrites": [
    { "source": "/es",        "destination": "/index.html" },
    { "source": "/es/:path*", "destination": "/index.html" },
    { "source": "/en",        "destination": "/index.html" },
    { "source": "/en/:path*", "destination": "/index.html" },
    { "source": "/(.*)",      "destination": "/404.html" }
  ]
}
